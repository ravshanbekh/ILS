# Environment
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:1234@localhost:5432/normativ_tizim

# JWT
JWT_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Boshlang'ich admin (server birinchi ishga tushganda avtomatik yaratiladi)
INITIAL_ADMIN_LOGIN=admin
INITIAL_ADMIN_PASSWORD=change-this-strong-password
INITIAL_ADMIN_FULLNAME=Administrator

# Demo rejimi (taqdimot uchun) — production'da odatda kerak emas
DEMO_MODE=false

# Telegram Bot (@BotFather dan olingan token) — ixtiyoriy
TELEGRAM_BOT_TOKEN=
