// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  admin
  teacher
  student
  filial_rahbari
  assistant
  moliya_rahbari
  kassir
  administrator
  nazoratchi
  hr_rahbari
  sotuv_operatori
  farrosh
  robototexnika_ustoz
  call_operatori
}

enum SubmissionStatus {
  pending
  checked
}

enum SubmissionResult {
  green
  blue
  red
}

// ============ MODELS ============

/// Foydalanuvchilar (Admin, O'qituvchi, O'quvchi)
model User {
  id           String   @id @default(uuid()) @db.Uuid
  fullName     String   @map("full_name") @db.VarChar(100)
  login        String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash")
  role         UserRole
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  teacherGroups      Group[]               @relation("TeacherGroups")
  groupStudents      GroupStudent[]
  submissions        Submission[]          @relation("StudentSubmissions")
  checkedBy          Submission[]          @relation("CheckedByTeacher")
  notifications      Notification[]
  auditLogs          AuditLog[]
  checklistEntries   DailyChecklistEntry[]
  frozenEntries      StudentFreeze[]       @relation("FrozenStudents")
  frozenByEntries    StudentFreeze[]       @relation("FrozenBy")
  monitoringCalls    MonitoringCall[]      @relation("MonitoringCalledBy")
  monitoringNotes    MonitoringNote[]      @relation("MonitoringNotes")
  feedbacksWritten   StudentFeedback[]     @relation("FeedbackByStudent")
  feedbacksReceived  StudentFeedback[]     @relation("FeedbackForTeacher")
  telegramLinks      TelegramLink[]        @relation("TelegramStudentLinks")
  feedbackStudent    TelegramFeedback[]    @relation("FeedbackStudent")
  feedbackTeacher    TelegramFeedback[]    @relation("FeedbackTeacher")
  // Exam relations
  createdExams       Exam[]                @relation("ExamCreator")
  examParticipations ExamParticipant[]     @relation("ExamParticipants")
  gradedExams        ExamParticipant[]     @relation("ExamGrader")
  createdQuizzes     LiveQuiz[]            @relation("QuizCreator")

  @@map("users")
}

/// Guruhlar
model Group {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(50)
  teacherId String?  @map("teacher_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  teacher         User?             @relation("TeacherGroups", fields: [teacherId], references: [id])
  groupStudents   GroupStudent[]
  groupNormatives GroupNormative[]
  submissions     Submission[]
  rankingCache    RankingCache[]
  monitoringCalls MonitoringCall[]
  feedbacks       StudentFeedback[]

  @@map("groups")
}

/// Kategoriyalar (Yo'nalishlar: Foundation, Frontend, Backend)
model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  normatives Normative[]
  exams      Exam[]

  @@map("categories")
}

/// Guruh-O'quvchi bog'liqlik
model GroupStudent {
  id        String   @id @default(uuid()) @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  joinedAt  DateTime @default(now()) @map("joined_at")

  // Relations
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
  @@map("group_students")
}

/// Normativlar (Funksiya/Vazifalar)
model Normative {
  id          String   @id @default(uuid()) @db.Uuid
  taskNumber  Int      @map("task_number")
  title       String
  description String?
  timeLimit   Int?     @map("time_limit")
  url         String?
  maxScore    Int      @default(40) @map("max_score")
  isActive    Boolean  @default(true) @map("is_active")
  categoryId  String?  @map("category_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  category        Category?        @relation(fields: [categoryId], references: [id])
  groupNormatives GroupNormative[]
  submissions     Submission[]

  @@map("normatives")
}

/// Guruh-Normativ bog'liqlik
model GroupNormative {
  id          String   @id @default(uuid()) @db.Uuid
  groupId     String   @map("group_id") @db.Uuid
  normativeId String   @map("normative_id") @db.Uuid
  assignedAt  DateTime @default(now()) @map("assigned_at")

  // Relations
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  normative Normative @relation(fields: [normativeId], references: [id], onDelete: Cascade)

  @@unique([groupId, normativeId])
  @@map("group_normatives")
}

/// O'quvchi Topshiriqlari (Submissions)
model Submission {
  id          String           @id @default(uuid()) @db.Uuid
  studentId   String           @map("student_id") @db.Uuid
  normativeId String           @map("normative_id") @db.Uuid
  groupId     String?          @map("group_id") @db.Uuid
  youtubeUrl  String           @map("youtube_url")
  submittedAt DateTime         @default(now()) @map("submitted_at")
  status      SubmissionStatus @default(pending)
  canResubmit Boolean          @default(false) @map("can_resubmit")

  // O'qituvchi tekshirgandan so'ng
  checkedById String?           @map("checked_by") @db.Uuid
  checkedAt   DateTime?         @map("checked_at")
  result      SubmissionResult?
  score       Int               @default(0)
  comment     String?

  // Relations
  student   User      @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  normative Normative @relation(fields: [normativeId], references: [id], onDelete: Cascade)
  group     Group?    @relation(fields: [groupId], references: [id])
  checkedBy User?     @relation("CheckedByTeacher", fields: [checkedById], references: [id])

  @@unique([studentId, normativeId])
  @@map("submissions")
}

/// Reyting Cache (kunlik hisoblash)
model RankingCache {
  id          String   @id @default(uuid()) @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  groupId     String?  @map("group_id") @db.Uuid
  totalScore  Int      @default(0) @map("total_score")
  completed   Int      @default(0)
  pending     Int      @default(0)
  rankInGroup Int?     @map("rank_in_group")
  rankOverall Int?     @map("rank_overall")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  group Group? @relation(fields: [groupId], references: [id])

  @@map("ranking_cache")
}

/// Audit Log (kim nima qildi)
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  targetType String?  @map("target_type") @db.VarChar(50)
  targetId   String?  @map("target_id") @db.Uuid
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

/// Xabarnomalar
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String
  body      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

/// Kunlik Checklist elementlari (template)
model ChecklistItem {
  id          String   @id @default(uuid()) @db.Uuid
  role        UserRole
  order       Int
  score       Int      @default(1)
  section     String?  @db.VarChar(200)
  category    String   @db.VarChar(200)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  entries DailyChecklistEntry[]

  @@map("checklist_items")
}

/// Kunlik Checklist yozuvlari (kim, qachon, bajarildimi)
model DailyChecklistEntry {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  checklistItemId String    @map("checklist_item_id") @db.Uuid
  date            DateTime  @db.Date
  isDone          Boolean   @default(false) @map("is_done")
  doneAt          DateTime? @map("done_at")

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklistItem ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  @@unique([userId, checklistItemId, date])
  @@map("daily_checklist_entries")
}

// ============ FREEZE SYSTEM ============

enum FreezeReason {
  moliyaviy // Moliyaviy (to'lov)
  kochib_ketish // Ko'chib/safarga ketish
  vaqtincha_toxtatgan // Vaqtincha to'xtatgan (qaytish rejasi bor)
  kasallik // Kasallik
  kanikul // Lager/Kanikul (vaqtinchalik)
  boshqa_fan // Boshqa fan/sertifikatga o'tish
  kurs_tugadi // Kurs tugadi, davomi yo'q
  motivatsiya // Motivatsiya/oilaviy sabab
  ish_tadbir // Ishga ketish/oilaviy tadbir
  universitet // Universitet sessiyasi
  shaxsiy // Shaxsiy sabab
  oqituvchidan_norozi // O'qituvchidan norozilik
  boshqa // Boshqa
  sabab_korsatilmagan // Sabab ko'rsatilmagan
}

/// Muzlatilgan O'quvchilar (Ketish Hisoboti)
model StudentFreeze {
  id           String       @id @default(uuid()) @db.Uuid
  studentId    String       @map("student_id") @db.Uuid
  frozenById   String       @map("frozen_by_id") @db.Uuid
  frozenAt     DateTime     @default(now()) @map("frozen_at")
  month        Int // Muzlatilgan oy (1-12)
  year         Int // Muzlatilgan yil (2025, 2026...)
  reason       FreezeReason // Sabab kategoriyasi
  detailedNote String?      @map("detailed_note") @db.VarChar(1000)
  phone        String?      @db.VarChar(30)
  startDate    DateTime?    @map("start_date") // Kursga kirgan sana
  filial       String?      @db.VarChar(100) // Filial (Beeline, Stomatologiya...)

  // Muzlatish vaqtidagi snapshot (o'zgarmas qoladi)
  studentName String  @map("student_name") @db.VarChar(200)
  teacherName String? @map("teacher_name") @db.VarChar(200)
  groupName   String? @map("group_name") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  student  User @relation("FrozenStudents", fields: [studentId], references: [id])
  frozenBy User @relation("FrozenBy", fields: [frozenById], references: [id])

  @@map("student_freezes")
}

// ============ MONITORING SYSTEM ============

enum MonitoringMood {
  yaxshi // 😊 Hamma narsa yaxshi
  oddiy // 😐 Alohida shikoyat yo'q
  yomon // 😟 Muammo bor, norozilik
  javob_bermadi // 📵 Telefonga javob bermadi
}

/// Monitoring qo'ng'iroq sessiyasi (administrator qaysi guruhga qo'ng'iroq qildi)
model MonitoringCall {
  id         String   @id @default(uuid()) @db.Uuid
  groupId    String   @map("group_id") @db.Uuid
  calledById String   @map("called_by_id") @db.Uuid
  callDate   DateTime @default(now()) @map("call_date")
  summary    String?  @db.VarChar(500) // Umumiy qisqa izoh
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  group    Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  calledBy User             @relation("MonitoringCalledBy", fields: [calledById], references: [id])
  notes    MonitoringNote[]

  @@map("monitoring_calls")
}

/// Har bir o'quvchi uchun monitoring fikri
model MonitoringNote {
  id        String         @id @default(uuid()) @db.Uuid
  callId    String         @map("call_id") @db.Uuid
  studentId String         @map("student_id") @db.Uuid
  mood      MonitoringMood
  note      String         @db.VarChar(2000)
  tags      String[]       @default([])
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  // Relations
  call    MonitoringCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  student User           @relation("MonitoringNotes", fields: [studentId], references: [id])

  @@map("monitoring_notes")
}

// ============ TELEGRAM BOT SYSTEM ============

/// Telegram Chat bog'lanishi (Ota-ona/Operator → O'quvchi)
model TelegramLink {
  id               String   @id @default(uuid()) @db.Uuid
  telegramId       BigInt   @unique @map("telegram_id") // Telegram user ID
  chatId           BigInt   @map("chat_id") // Telegram chat ID
  studentId        String   @map("student_id") @db.Uuid // Bog'langan o'quvchi
  role             String   @default("parent") @db.VarChar(20) // "parent" | "operator"
  fullName         String?  @map("full_name") @db.VarChar(200)
  username         String?  @db.VarChar(100) // @username
  isActive         Boolean  @default(true) @map("is_active")
  language         String   @default("uz") @db.VarChar(5) // "uz" | "ru"
  notifyOnCheck    Boolean  @default(true) @map("notify_on_check")
  notifyOnRank     Boolean  @default(true) @map("notify_on_rank")
  notifyWeekly     Boolean  @default(true) @map("notify_weekly")
  notifyInactivity Boolean  @default(true) @map("notify_inactivity")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  student User @relation("TelegramStudentLinks", fields: [studentId], references: [id])

  @@map("telegram_links")
}

/// Telegram orqali yuborilgan feedback (ota-ona → o'qituvchi)
model TelegramFeedback {
  id         String    @id @default(uuid()) @db.Uuid
  telegramId BigInt    @map("telegram_id")
  studentId  String    @map("student_id") @db.Uuid
  teacherId  String?   @map("teacher_id") @db.Uuid
  message    String    @db.VarChar(2000)
  isRead     Boolean   @default(false) @map("is_read")
  repliedAt  DateTime? @map("replied_at")
  replyText  String?   @map("reply_text") @db.VarChar(2000)
  createdAt  DateTime  @default(now()) @map("created_at")

  // Relations
  student User  @relation("FeedbackStudent", fields: [studentId], references: [id])
  teacher User? @relation("FeedbackTeacher", fields: [teacherId], references: [id])

  @@map("telegram_feedbacks")
}

/// AI tomonidan yaratilgan tahlil hisobotlari (cache)
model MonitoringAIReport {
  id         String   @id @default(uuid()) @db.Uuid
  groupId    String?  @map("group_id") @db.Uuid
  teacherId  String?  @map("teacher_id") @db.Uuid
  reportType String   @db.VarChar(50) // "group_analysis" | "teacher_analysis" | "overall"
  content    String // AI javob matni (plain text)
  period     String   @db.VarChar(20) // "2026-06"
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("monitoring_ai_reports")
}

/// Student feedback for teacher
model StudentFeedback {
  id          String   @id @default(uuid()) @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  teacherId   String   @map("teacher_id") @db.Uuid
  groupId     String   @map("group_id") @db.Uuid
  rating      Int // 1-5
  comment     String?  @db.VarChar(500)
  isAnonymous Boolean  @default(true) @map("is_anonymous")
  createdAt   DateTime @default(now()) @map("created_at")

  student User  @relation("FeedbackByStudent", fields: [studentId], references: [id])
  teacher User  @relation("FeedbackForTeacher", fields: [teacherId], references: [id])
  group   Group @relation(fields: [groupId], references: [id])

  @@map("student_feedbacks")
}

// ============================================================
//  EXAM SYSTEM (3-bosqichli rasmiy imtihon)
// ============================================================

enum ExamStatus {
  draft
  active
  completed
  cancelled
}

enum ExamParticipantStatus {
  joined
  in_progress
  submitted
  timeout
}

/// Rasmiy imtihon
model Exam {
  id          String     @id @default(uuid()) @db.Uuid
  title       String     @db.VarChar(200)
  description String?    @db.VarChar(500)
  categoryId  String?    @map("category_id") @db.Uuid
  createdById String     @map("created_by_id") @db.Uuid
  accessCode  String     @unique @map("access_code") @db.VarChar(20)
  startsAt    DateTime   @map("starts_at")
  expiresAt   DateTime   @map("expires_at")
  status      ExamStatus @default(draft)
  testCount   Int        @default(20) @map("test_count")
  isGlobal    Boolean    @default(false) @map("is_global")
  templateId  String?    @map("template_id") @db.Uuid

  // Maksimal ballar
  maxTestScore    Int @default(40) @map("max_test_score")
  maxAiScore      Int @default(20) @map("max_ai_score")
  maxProjectScore Int @default(40) @map("max_project_score")

  // Dinamik bosqich nomlari
  step2Name String @default("AI video taqdimot") @map("step2_name") @db.VarChar(100)
  step3Name String @default("Loyiha (Youtube link)") @map("step3_name") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  category     Category?         @relation(fields: [categoryId], references: [id])
  createdBy    User              @relation("ExamCreator", fields: [createdById], references: [id])
  template     Exam?             @relation("ExamTemplate", fields: [templateId], references: [id])
  sessions     Exam[]            @relation("ExamTemplate")
  questions    ExamQuestion[]
  participants ExamParticipant[]

  @@map("exams")
}

/// Imtihon savollari
model ExamQuestion {
  id       String  @id @default(uuid()) @db.Uuid
  examId   String  @map("exam_id") @db.Uuid
  question String
  imageUrl String? @map("image_url")
  options  Json // ["variant A", "variant B", "variant C", "variant D"]
  correct  Int // 0-3 (to'g'ri javob indeksi)
  order    Int     @default(0)

  exam    Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers ExamAnswer[]

  @@map("exam_questions")
}

/// Imtihon ishtirokchisi
model ExamParticipant {
  id          String                @id @default(uuid()) @db.Uuid
  examId      String                @map("exam_id") @db.Uuid
  studentId   String                @map("student_id") @db.Uuid
  status      ExamParticipantStatus @default(joined)
  startedAt   DateTime?             @map("started_at")
  submittedAt DateTime?             @map("submitted_at")

  // Test natijalari
  testScore    Int? @map("test_score")
  correctCount Int? @map("correct_count")

  // Video havolalar
  aiVideoUrl      String? @map("ai_video_url")
  projectVideoUrl String? @map("project_video_url")

  // O'qituvchi tomonidan baho
  aiScore        Int?      @map("ai_score")
  projectScore   Int?      @map("project_score")
  totalScore     Int?      @map("total_score")
  aiComment      String?   @map("ai_comment") @db.VarChar(1000)
  projectComment String?   @map("project_comment") @db.VarChar(1000)
  gradedById     String?   @map("graded_by_id") @db.Uuid
  gradedAt       DateTime? @map("graded_at")

  createdAt DateTime @default(now()) @map("created_at")

  exam     Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  student  User         @relation("ExamParticipants", fields: [studentId], references: [id])
  gradedBy User?        @relation("ExamGrader", fields: [gradedById], references: [id])
  answers  ExamAnswer[]

  @@unique([examId, studentId])
  @@map("exam_participants")
}

/// Imtihon javoblari (test bosqichi)
model ExamAnswer {
  id             String   @id @default(uuid()) @db.Uuid
  participantId  String   @map("participant_id") @db.Uuid
  questionId     String   @map("question_id") @db.Uuid
  selectedOption Int      @map("selected_option")
  isCorrect      Boolean  @map("is_correct")
  answeredAt     DateTime @default(now()) @map("answered_at")

  participant ExamParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  question    ExamQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([participantId, questionId])
  @@map("exam_answers")
}

// ============================================================
//  LIVE QUIZ SYSTEM (Kahoot/Wayground uslubi)
// ============================================================

enum QuizStatus {
  waiting
  active
  finished
}

/// Real-time interaktiv quiz musiqalari
model QuizMusic {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(150)
  url       String   // music file path / url
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  liveQuizzes LiveQuiz[]

  @@map("quiz_musics")
}

/// Real-time interaktiv quiz
model LiveQuiz {
  id          String     @id @default(uuid()) @db.Uuid
  title       String     @db.VarChar(200)
  description String?    @db.VarChar(500)
  code        String     @unique @db.VarChar(10)
  createdById String     @map("created_by_id") @db.Uuid
  status      QuizStatus @default(waiting)
  currentQ    Int        @default(-1) @map("current_q") // -1 = hali boshlanmagan
  timePerQ    Int        @default(20) @map("time_per_q") // soniyada
  isGlobal          Boolean    @default(false) @map("is_global") // Admin tomonidan yaratilgan markaz quizlari
  activeQuestionIds Json?      @map("active_question_ids") // Random tanlangan 20 ta savol IDlari
  musicId           String?    @map("music_id") @db.Uuid
  createdAt         DateTime   @default(now()) @map("created_at")

  createdBy User               @relation("QuizCreator", fields: [createdById], references: [id])
  music     QuizMusic?         @relation(fields: [musicId], references: [id])
  questions LiveQuizQuestion[]
  players   LiveQuizPlayer[]

  @@map("live_quizzes")
}

/// Live quiz savoli
model LiveQuizQuestion {
  id       String  @id @default(uuid()) @db.Uuid
  quizId   String  @map("quiz_id") @db.Uuid
  question String
  options  Json // ["A","B","C","D"]
  correct  Int
  order    Int     @default(0)
  imageUrl String? @map("image_url")

  quiz    LiveQuiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers LiveQuizAnswer[]

  @@map("live_quiz_questions")
}

/// Live quiz o'yinchisi (tizimdan tashqari, faqat ism bilan)
model LiveQuizPlayer {
  id       String   @id @default(uuid()) @db.Uuid
  quizId   String   @map("quiz_id") @db.Uuid
  fullName String   @map("full_name") @db.VarChar(100)
  score    Int      @default(0)
  streak   Int      @default(0)
  rank     Int?
  joinedAt DateTime @default(now()) @map("joined_at")

  quiz    LiveQuiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers LiveQuizAnswer[]

  @@map("live_quiz_players")
}

/// Live quiz javob
model LiveQuizAnswer {
  id         String  @id @default(uuid()) @db.Uuid
  playerId   String  @map("player_id") @db.Uuid
  questionId String  @map("question_id") @db.Uuid
  selected   Int
  isCorrect  Boolean @map("is_correct")
  timeMs     Int     @map("time_ms") // Javob tezligi (ms)
  points     Int     @default(0)

  player   LiveQuizPlayer   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  question LiveQuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([playerId, questionId])
  @@map("live_quiz_answers")
}
