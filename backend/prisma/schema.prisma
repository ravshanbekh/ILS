// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  admin
  teacher
  student
  filial_rahbari
  assistant
  moliya_rahbari
  kassir
  administrator
  nazoratchi
  hr_rahbari
  sotuv_operatori
  farrosh
  robototexnika_ustoz
  call_operatori
}

enum SubmissionStatus {
  pending
  checked
}

enum SubmissionResult {
  green
  blue
  red
}

// ============ MODELS ============

/// Foydalanuvchilar (Admin, O'qituvchi, O'quvchi)
model User {
  id           String   @id @default(uuid()) @db.Uuid
  fullName     String   @map("full_name") @db.VarChar(100)
  login        String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash")
  role         UserRole
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  teacherGroups  Group[]          @relation("TeacherGroups")
  groupStudents  GroupStudent[]
  submissions    Submission[]     @relation("StudentSubmissions")
  checkedBy      Submission[]     @relation("CheckedByTeacher")
  notifications       Notification[]
  auditLogs           AuditLog[]
  checklistEntries    DailyChecklistEntry[]

  @@map("users")
}

/// Guruhlar
model Group {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(50)
  teacherId String?  @map("teacher_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  teacher        User?            @relation("TeacherGroups", fields: [teacherId], references: [id])
  groupStudents  GroupStudent[]
  groupNormatives GroupNormative[]
  submissions    Submission[]
  rankingCache   RankingCache[]

  @@map("groups")
}

/// Kategoriyalar (Yo'nalishlar: Foundation, Frontend, Backend)
model Category {
  id          String      @id @default(uuid()) @db.Uuid
  name        String      @unique @db.VarChar(100)
  description String?
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  normatives  Normative[]

  @@map("categories")
}

/// Guruh-O'quvchi bog'liqlik
model GroupStudent {
  id        String   @id @default(uuid()) @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  joinedAt  DateTime @default(now()) @map("joined_at")

  // Relations
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
  @@map("group_students")
}

/// Normativlar (Funksiya/Vazifalar)
model Normative {
  id          String   @id @default(uuid()) @db.Uuid
  taskNumber  Int      @map("task_number")
  title       String
  description String?
  timeLimit   Int?     @map("time_limit")
  url         String?
  maxScore    Int      @default(40) @map("max_score")
  isActive    Boolean  @default(true) @map("is_active")
  categoryId  String?  @map("category_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  category        Category?         @relation(fields: [categoryId], references: [id])
  groupNormatives GroupNormative[]
  submissions     Submission[]

  @@map("normatives")
}

/// Guruh-Normativ bog'liqlik
model GroupNormative {
  id          String   @id @default(uuid()) @db.Uuid
  groupId     String   @map("group_id") @db.Uuid
  normativeId String   @map("normative_id") @db.Uuid
  assignedAt  DateTime @default(now()) @map("assigned_at")

  // Relations
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  normative Normative @relation(fields: [normativeId], references: [id], onDelete: Cascade)

  @@unique([groupId, normativeId])
  @@map("group_normatives")
}

/// O'quvchi Topshiriqlari (Submissions)
model Submission {
  id          String           @id @default(uuid()) @db.Uuid
  studentId   String           @map("student_id") @db.Uuid
  normativeId String           @map("normative_id") @db.Uuid
  groupId     String?          @map("group_id") @db.Uuid
  youtubeUrl  String           @map("youtube_url")
  submittedAt DateTime         @default(now()) @map("submitted_at")
  status      SubmissionStatus @default(pending)
  canResubmit Boolean          @default(false) @map("can_resubmit")

  // O'qituvchi tekshirgandan so'ng
  checkedById String?          @map("checked_by") @db.Uuid
  checkedAt   DateTime?        @map("checked_at")
  result      SubmissionResult?
  score       Int              @default(0)
  comment     String?

  // Relations
  student   User      @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  normative Normative @relation(fields: [normativeId], references: [id], onDelete: Cascade)
  group     Group?    @relation(fields: [groupId], references: [id])
  checkedBy User?     @relation("CheckedByTeacher", fields: [checkedById], references: [id])

  @@unique([studentId, normativeId, groupId])
  @@map("submissions")
}

/// Reyting Cache (kunlik hisoblash)
model RankingCache {
  id           String   @id @default(uuid()) @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  groupId      String?  @map("group_id") @db.Uuid
  totalScore   Int      @default(0) @map("total_score")
  completed    Int      @default(0)
  pending      Int      @default(0)
  rankInGroup  Int?     @map("rank_in_group")
  rankOverall  Int?     @map("rank_overall")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  group Group? @relation(fields: [groupId], references: [id])

  @@map("ranking_cache")
}

/// Audit Log (kim nima qildi)
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  targetType String?  @map("target_type") @db.VarChar(50)
  targetId   String?  @map("target_id") @db.Uuid
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

/// Xabarnomalar
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String
  body      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

/// Kunlik Checklist elementlari (template)
model ChecklistItem {
  id          String   @id @default(uuid()) @db.Uuid
  role        UserRole
  order       Int
  score       Int      @default(1)
  section     String?  @db.VarChar(200)
  category    String   @db.VarChar(200)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  entries DailyChecklistEntry[]

  @@map("checklist_items")
}

/// Kunlik Checklist yozuvlari (kim, qachon, bajarildimi)
model DailyChecklistEntry {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  checklistItemId String        @map("checklist_item_id") @db.Uuid
  date            DateTime      @db.Date
  isDone          Boolean       @default(false) @map("is_done")
  doneAt          DateTime?     @map("done_at")

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklistItem ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  @@unique([userId, checklistItemId, date])
  @@map("daily_checklist_entries")
}
